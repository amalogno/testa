# Server
PORT=3000
NODE_ENV=production
ALLOWED_ORIGIN=https://marketplace.yourtrusteddomain.com

# Database (Least Privilege DB User Credentials)
MONGO_URI=mongodb+srv://<api_user>:<secure_random_password>@cluster.mongodb.net/marketplace

# JWT (Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_secure_random_hex_string
JWT_EXPIRES_IN=15m
JWT_ISSUER=secure-marketplace-api
JWT_AUDIENCE=secure-marketplace-client